rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catalog: public read only. Edit trunks/branches/stems via Firebase Console or Admin SDK.
    match /trunks/{trunkId} {
      allow read: if true;
      allow write: if false;
    }
    match /branches/{branchId} {
      allow read: if true;
      allow write: if false;
    }
    match /content_catalog/{stemId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /stemProgress/{stemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /forest/{stemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
