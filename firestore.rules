rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catalog: public read. Writes only for signed-in users (one-time seed from app).
    // After you seed production data, change these to `allow write: if false` and edit via Console/Admin SDK.
    match /trunks/{trunkId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /branches/{branchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /content_catalog/{stemId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /stemProgress/{stemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /forest/{stemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
