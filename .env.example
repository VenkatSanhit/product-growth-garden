# Copy this file to `.env` in the same folder as `package.json` and fill in values.
# Never commit real keys — `.env` is gitignored.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Analytics (not required by the app init in `src/lib/firebase.ts`)
# VITE_FIREBASE_MEASUREMENT_ID=

# "true" shows the one-time Firestore seed control on the landing page.
VITE_ENABLE_FIREBASE_SEED=
